{
  "indexes": [
    // ─────────────────────────────────────────────
    // CURRENT: sort by dueDate (ascending)
    // Single-field index — created automatically by
    // Firestore on first orderBy('dueDate') query.
    // Manually declared here for documentation.
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "dueDate", "order": "ASCENDING" }
      ]
    },

    // ─────────────────────────────────────────────
    // FUTURE: filter by isCompleted, sort by dueDate
    // Used when "Pending" or "Completed" chips are
    // active AND results are ordered by dueDate.
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isCompleted", "order": "ASCENDING" },
        { "fieldPath": "dueDate", "order": "ASCENDING" }
      ]
    },

    // ─────────────────────────────────────────────
    // FUTURE: filter by priority, sort by dueDate
    // Used when a priority chip is active AND results
    // are ordered by dueDate.
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "priority", "order": "ASCENDING" },
        { "fieldPath": "dueDate", "order": "ASCENDING" }
      ]
    },

    // ─────────────────────────────────────────────
    // FUTURE: filter by isCompleted AND priority,
    //          sort by dueDate
    // Used when both status and priority chips are
    // active with dueDate ordering.
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isCompleted", "order": "ASCENDING" },
        { "fieldPath": "priority", "order": "ASCENDING" },
        { "fieldPath": "dueDate", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
